# GitHub token with repo + gist scope
GITHUB_TOKEN=ghp_...

# The state Gist ID
GIST_ID=06c02c97ffc0d11458687f1ed998d9e5

# Dashboard gate. In production the dashboard must sit behind EXACTLY ONE of:
#   (a) app HTTP Basic auth — set both vars below; or
#   (b) Vercel Deployment Protection (Vercel Authentication) — then set
#       DASHBOARD_AUTH_DISABLED=1 to turn off the app's own Basic auth.
# With neither, production fails CLOSED (503) — never public (the dashboard can
# trigger runs and post tweets).
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
# DASHBOARD_AUTH_DISABLED=1
